<?xml version="1.0" encoding="utf-8"?>
<!-- Blank drawable used as the native splash screen icon.
     Android 12+ always shows an icon on the splash screen; if none is set,
     it falls back to ic_launcher. By setting this as the icon we show
     nothing — the splash appears as a plain dark background, and our
     Compose SplashScreen handles the logo animation. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Solid fill matching the splash background (#0B0D18), no visible icon -->
    <path
        android:fillColor="#0B0D18"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />
</vector>
