<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Brainland" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Native splash screen: background color + blank icon so Android 12+
             does NOT fall back to ic_launcher. The Compose SplashScreen handles
             the real logo animation. -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">#0B0D18</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/splash_blank</item>

        <item name="android:statusBarColor">#0B0D18</item>
        <item name="android:navigationBarColor">#0B0D18</item>
    </style>
</resources>